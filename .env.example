# Copy to .env and fill in. zot loads .env from the working directory.

# Backend credentials. The default "cbk" backend uses CHATBOTKIT_API_SECRET;
# the "relay" backend uses RELAY_API_KEY (your own OpenAI/OpenRouter key).
CHATBOTKIT_API_SECRET=
# RELAY_API_KEY=

# Optional: override config fields via ZOT_<PATH> (see configs/zot.example.yaml).
# ZOT_AGENT_MODEL=kimi-k2.7-code
# ZOT_AGENT_MAX_ITERATIONS=1000
# ZOT_DEFAULT_BACKEND=cbk
# ZOT_UI_DIFF=true   # show syntax-highlighted diffs (same as --diff)
# ZOT_UI_PLAIN=true  # force unstyled streaming output (same as --plain)
